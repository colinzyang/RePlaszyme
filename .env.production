# Production environment variables for RePlaszyme frontend
# This file is used during production builds (npm run build)

# Backend API URL (production)
VITE_API_URL=https://api.plaszyme.org

# Optional: Gemini AI API key for predictions
# VITE_GEMINI_API_KEY=your_gemini_api_key_here

# Optional: Custom model endpoint for predictions
# VITE_PRIVATE_MODEL_URL=https://your-model.com/api
